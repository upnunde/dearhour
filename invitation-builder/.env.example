# 프로덕션에서는 https://도메인 형태로 고정. 로컬에서 next dev 포트가 3000이 아니면 비워 두거나 실제 포트와 맞출 것(OAuth PKCE 쿠키 도메인 일치).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Postgres (Prisma)
DATABASE_URL=
DIRECT_URL=

# (선택) 임시 로그인 — npm run dev: 익명 허용( Auth → Settings → Allow anonymous sign-ins ) 또는 아래 테스트 계정
# 프로덕션에서 쓰려면 ENABLE_DEV_TEMP_LOGIN=true + 아래 이메일 계정
# ENABLE_DEV_TEMP_LOGIN=true
# DEV_TEMP_LOGIN_EMAIL=dev@example.com
# DEV_TEMP_LOGIN_PASSWORD=
# 네이버 클라우드 플랫폼 — 동일 앱에서 Maps + Geocoding API 사용 권장
# https://www.ncloud.com/ → AI·NAVER API → Application 등록
# 이 파일을 복사해 .env.local 로 저장한 뒤 값만 채우면 됩니다.
NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID=
# 오시는 길 미리보기: 서버가 네이버 Static Map API로 이미지를 받음 → NCP에서 Static Map 사용 ON 필수.
# (브라우저 JS 지도는 Web 서비스 URL 제약이 있어, 미리보기는 정적 지도로 통일했습니다.)
# 지오코딩(주소→좌표) — 서버 전용. 미리보기 지도 핀 위치 정확도 향상
NAVER_MAPS_CLIENT_SECRET=
# (선택) 공개 Client ID와 다른 키 ID를 쓸 때만 설정. 비우면 NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID 사용
# NAVER_MAPS_API_KEY_ID=

# 토스페이먼츠 결제위젯 — https://developers.tosspayments.com/ API 키 메뉴에서 결제위젯 연동 키(테스트/라이브) 발급
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
# 서버에서만 사용 (절대 클라이언트 번들에 넣지 말 것). 결제위젯 시크릿 키
TOSS_PAYMENTS_WIDGET_SECRET_KEY=
